{
  "name": "pilltracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "backend:dev": "nodemon backend/src/server.js",
    "backend:start": "node backend/src/server.js",
    "test:backend:smoke": "node backend/tests/smoke/health.mjs",
    "repo:format": "prettier . --write",
